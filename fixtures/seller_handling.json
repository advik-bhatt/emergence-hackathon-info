{
  "slug": "seller_handling",
  "nl_question": "For each seller with at least 50 delivered items, compute the 95th percentile of seller handling days (order_approved_at to order_delivered_carrier_date), the median handling days, and the number of delivered items.",
  "sql": "SELECT oi.\"seller_id\", COUNT(*) AS delivered_items, PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY DATEDIFF('day', TRY_TO_TIMESTAMP(o.\"order_approved_at\"), TRY_TO_TIMESTAMP(o.\"order_delivered_carrier_date\"))) AS p95_handling_days, PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY DATEDIFF('day', TRY_TO_TIMESTAMP(o.\"order_approved_at\"), TRY_TO_TIMESTAMP(o.\"order_delivered_carrier_date\"))) AS median_handling_days FROM \"BRAZILIAN_E_COMMERCE\".\"BRAZILIAN_E_COMMERCE\".\"OLIST_ORDER_ITEMS\" oi JOIN \"BRAZILIAN_E_COMMERCE\".\"BRAZILIAN_E_COMMERCE\".\"OLIST_ORDERS\" o ON oi.\"order_id\" = o.\"order_id\" WHERE o.\"order_status\" = 'delivered' AND TRY_TO_TIMESTAMP(o.\"order_approved_at\") IS NOT NULL AND TRY_TO_TIMESTAMP(o.\"order_delivered_carrier_date\") IS NOT NULL GROUP BY oi.\"seller_id\" HAVING COUNT(*) >= 50 ORDER BY p95_handling_days DESC",
  "columns": [
    "seller_id",
    "DELIVERED_ITEMS",
    "P95_HANDLING_DAYS",
    "MEDIAN_HANDLING_DAYS"
  ],
